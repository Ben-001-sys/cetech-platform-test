~/src/cetech-platform/.env.example
# Project
COMPOSE_PROJECT_NAME=cetech
CETECH_ENV=local
CETECH_PUBLIC_HOST=cetech.test
CETECH_PUBLIC_SCHEME=https

# Pinned container versions
TRAEFIK_VERSION=3.7.1
NGINX_VERSION=1.30.4
MARIADB_VERSION=11.8.8
VALKEY_VERSION=9.1.0-alpine3.23
MAILPIT_VERSION=v1.30.4

# WordPress/PHP build
WORDPRESS_VERSION=7.0.2
PHP_IMAGE=php:8.4.22-fpm-bookworm@sha256:66cf4b823e8dcde762ffa705b8589d592d709e0705ce6fdcd832d9a7ea4ed0f3
WP_CLI_IMAGE=wordpress:cli-2.12.0-php8.4
PHPREDIS_VERSION=6.3.0

# MariaDB
MARIADB_ROOT_PASSWORD=CHANGE_ME
CORPORATE_DB_NAME=cetech_corporate
CORPORATE_DB_USER=wp_corporate
CORPORATE_DB_PASSWORD=CHANGE_ME
STORE_DB_NAME=cetech_store_gh
STORE_DB_USER=wp_store_gh
STORE_DB_PASSWORD=CHANGE_ME
BLOG_DB_NAME=cetech_blog_en
BLOG_DB_USER=wp_blog_en
BLOG_DB_PASSWORD=CHANGE_ME

# Valkey
CORPORATE_VALKEY_PASSWORD=CHANGE_ME
STORE_VALKEY_PASSWORD=CHANGE_ME
BLOG_VALKEY_PASSWORD=CHANGE_ME

# WordPress salts — unique for every installation
CORPORATE_AUTH_KEY=CHANGE_ME
CORPORATE_SECURE_AUTH_KEY=CHANGE_ME
CORPORATE_LOGGED_IN_KEY=CHANGE_ME
CORPORATE_NONCE_KEY=CHANGE_ME
CORPORATE_AUTH_SALT=CHANGE_ME
CORPORATE_SECURE_AUTH_SALT=CHANGE_ME
CORPORATE_LOGGED_IN_SALT=CHANGE_ME
CORPORATE_NONCE_SALT=CHANGE_ME

STORE_AUTH_KEY=CHANGE_ME
STORE_SECURE_AUTH_KEY=CHANGE_ME
STORE_LOGGED_IN_KEY=CHANGE_ME
STORE_NONCE_KEY=CHANGE_ME
STORE_AUTH_SALT=CHANGE_ME
STORE_SECURE_AUTH_SALT=CHANGE_ME
STORE_LOGGED_IN_SALT=CHANGE_ME
STORE_NONCE_SALT=CHANGE_ME

BLOG_AUTH_KEY=CHANGE_ME
BLOG_SECURE_AUTH_KEY=CHANGE_ME
BLOG_LOGGED_IN_KEY=CHANGE_ME
BLOG_NONCE_KEY=CHANGE_ME
BLOG_AUTH_SALT=CHANGE_ME
BLOG_SECURE_AUTH_SALT=CHANGE_ME
BLOG_LOGGED_IN_SALT=CHANGE_ME
BLOG_NONCE_SALT=CHANGE_ME

# Initial local administrators
CORPORATE_ADMIN_USER=cetech_corporate_admin
CORPORATE_ADMIN_PASSWORD=CHANGE_ME
CORPORATE_ADMIN_EMAIL=corporate-admin@example.test

STORE_ADMIN_USER=cetech_store_admin
STORE_ADMIN_PASSWORD=CHANGE_ME
STORE_ADMIN_EMAIL=store-admin@example.test

BLOG_ADMIN_USER=cetech_blog_admin
BLOG_ADMIN_PASSWORD=CHANGE_ME
BLOG_ADMIN_EMAIL=blog-admin@example.test